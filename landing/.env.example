# ── Supabase ──────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard.
# The service-role key is SECRET — server-side only, never exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site config ───────────────────────────────────────────────────
# Public canonical URL (used for OG/Twitter meta + canonical link).
NEXT_PUBLIC_SITE_URL=https://moufida.ai

# Launch date (ISO 8601). Drives the countdown timer.
NEXT_PUBLIC_LAUNCH_DATE=2026-06-28T09:00:00Z
