# ---------------------------------------------------------------------------
# Moufida environment configuration. Copy to `.env` and adjust as needed:
#     cp .env.example .env
# The defaults below are wired for the docker-compose network and bring the
# full stack up without edits.
# ---------------------------------------------------------------------------

# --- Datastores ---
POSTGRES_USER=moufida
POSTGRES_PASSWORD=moufida
POSTGRES_DB=moufida
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://moufida:moufida@postgres:5432/moufida

REDIS_URL=redis://redis:6379/0
REDIS_METRICS_CHANNEL=moufida.metrics

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=moufida_kb

# --- Local model runtime (Ollama) ---
# Default: a host-native Ollama reached from containers via host.docker.internal.
# For the bundled container (compose --profile bundled-ollama) use http://ollama:11434.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Model used by the Axis 01 maturity classifier / chat (any pulled chat model).
OLLAMA_MODEL=mistral:7b
MOUFIDA_RUBRIC_MODEL=mistral:7b
MOUFIDA_MATURITY_MODEL=mistral:7b
MOUFIDA_ROADMAP_MODEL=mistral:8b
MOUFIDA_EMBED_MODEL=nomic-embed-text

# --- Service ports (host) ---
ORCHESTRATOR_PORT=
RAG_PORT=
# Axis ports are fixed at 8101-8110 inside the compose network.

# --- Orchestrator endpoints (compose-internal hostnames) ---
ORCHESTRATOR_URL=
RAG_URL=

# --- Misc ---
LOG_LEVEL=info
MODELS_DIR=./models
