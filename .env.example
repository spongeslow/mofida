# ---------------------------------------------------------------------------
# Moufida environment configuration. Copy to `.env` and adjust as needed:
#     cp .env.example .env
# The defaults below are wired for the docker-compose network and bring the
# full stack up without edits.
# ---------------------------------------------------------------------------

# --- Datastores ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=
DATABASE_URL=

REDIS_URL=
REDIS_METRICS_CHANNEL=

QDRANT_URL=
QDRANT_COLLECTION=

# --- Live web-search (self-hosted SearXNG, free, no API key) ---
SEARXNG_URL=http://searxng:8080

# --- Local model runtime (Ollama) ---
# Default: a host-native Ollama reached from containers via host.docker.internal.
# For the bundled container (compose --profile bundled-ollama) use http://ollama:11434.
OLLAMA_URL=
OLLAMA_BASE_URL=
# Model vars used inside Docker containers by axis services and orchestrator.
OLLAMA_MODEL=
OLLAMA_CHAT_MODEL=
# Multilingual embedding model (AR/FR/EN). bge-m3 -> 1024 dims; nomic-embed-text -> 768.
MOUFIDA_EMBED_MODEL=
MOUFIDA_EMBED_DIM=1024
# How long axis services wait for Ollama to respond (seconds). Increase on slow hardware.
OLLAMA_TIMEOUT=300

# --- Service ports (host) ---
ORCHESTRATOR_PORT=
RAG_PORT=
# Axis ports are fixed at 8101-8110 inside the compose network.

# --- Orchestrator endpoints (compose-internal hostnames) ---
ORCHESTRATOR_URL=
RAG_URL=
# Interpretability microservice (Phase H): Concept Bottleneck scoring + axis
# direction probe. Best-effort — leave default; the stack runs without it.
SIGNAL_URL=http://signal:8010

# --- Daemon ---
# Set to a real project UUID to enable project-scoped watchers (budget, competitor, legal, etc).
# Leave empty (or the nil UUID) to run only the KB-staleness checker.
MOUFIDA_PROJECT_ID=
DAEMON_STATE_DIR=         # watcher state dir (default inside container: /tmp/moufida-daemon-state)

# --- Composio (no-code bidirectional tool integrations, Phase G) ---
# 1. Go to https://app.composio.dev, sign up / log in, and create an organisation.
# 2. Go to Settings → API Keys, generate a new key, and copy it below.
# 3. Leave empty to disable all Composio-backed tools.
COMPOSIO_API_KEY=
# Optional — only needed for real-time push delivery.
# 1. Generate a random secret (e.g. `openssl rand -hex 32`).
# 2. Go to app.composio.dev → Settings → Webhook Subscriptions, set your
#    webhook URL (publicly reachable, e.g. via ngrok), and paste the same
#    secret there.  Without it the webhook endpoint returns 503.
# 3. The desktop polling fallback works fine without this — it fetches events
#    every ~5 min using the API key above.  Leave empty to rely on polling.
COMPOSIO_WEBHOOK_SECRET=
# OAuth callback the hosted popup returns to after authorisation. For the
# desktop app this can stay as the Composio-hosted success page (default).
COMPOSIO_REDIRECT_URL=https://app.composio.dev/redirect

# --- Observability admin panel (Phase H) ---
# When set, the admin panel (:3002) and /api/admin/* routes require this token
# (Bearer header, or ?token= for the SSE log stream). Leave empty for local-only
# use (auth disabled).
ADMIN_TOKEN=

# --- Misc ---
LOG_LEVEL=info
MODELS_DIR=./models
